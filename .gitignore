# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
env/
.venv/
.env/
path/to/venv/
# Catch any accidental `python -m venv path/to/venv` style directories
path/

# ---------------------------------------------------------------------------
# Secrets / credentials  (NEVER commit these)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
gcp/service_account.json
gcp/*.json
*.pem
*.key

# ---------------------------------------------------------------------------
# Generated user data (regenerated on every run)
# ---------------------------------------------------------------------------
data/csv/
data/json/
data/*.xlsx

# ---------------------------------------------------------------------------
# Generated visualizations (regenerated on every run)
# ---------------------------------------------------------------------------
static/images/

# ---------------------------------------------------------------------------
# HTTP response cache (requests-cache; see src/data/processor.py)
# ---------------------------------------------------------------------------
.cache/

# ---------------------------------------------------------------------------
# Tooling / editor / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Test / coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Frontend (Vite + React)
# ---------------------------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
.vercel
