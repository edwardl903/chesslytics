# ----------------------------------------------------------------------------
# Chesslytics environment variables (copy to `.env` and fill in)
# ----------------------------------------------------------------------------
# This file is committed; `.env` is gitignored.

# --- Flask --------------------------------------------------------------------
PORT=5001
FLASK_ENV=development

# --- Google Cloud / BigQuery --------------------------------------------------
# Local dev: drop your service account JSON at gcp/service_account.json
# Production / Heroku: paste the JSON contents into one of these env vars.
# The codebase currently reads BOTH of these (in different modules):
#   - api/bigquery_dashboard.py reads GOOGLE_APPLICATION_CREDENTIALS_JSON
#   - src/data/uploader.py     reads GOOGLE_CREDENTIALS
# For now, set both to the same value (the full JSON, on one line).
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS=
