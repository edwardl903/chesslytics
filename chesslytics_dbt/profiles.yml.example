# Copy this block into ~/.dbt/profiles.yml (merge with any existing profiles).
# The top-level key MUST match `profile:` in dbt_project.yml → chesslytics_dbt
#
#   cp profiles.yml.example ~/.dbt/profiles.yml   # only if you have no profiles yet
#   # or paste the chesslytics_dbt: section into ~/.dbt/profiles.yml

chesslytics_dbt:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: crucial-decoder-462021-m4
      # dbt outputs land here — isolated from the Flask app's raw dataset (test1)
      # sources.yml still reads FROM test1.raw_games; this is only where models are written
      dataset: chesslytics_dbt
      keyfile: /absolute/path/to/chesslyzer-experimental/gcp/service_account.json
      location: us-central1
      priority: interactive
      threads: 4
      timeout_seconds: 300
